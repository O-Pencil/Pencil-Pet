{
  "name": "pencil-pet",
  "version": "0.1.0",
  "description": "A cute desktop pet that monitors Pencil Multi-Agent system",
  "author": "Lucy <cl19940816@163.com>",
  "license": "MIT",
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "pnpm typecheck && electron-vite build",
    "typecheck": "tsc --noEmit",
    "dist": "pnpm build && electron-builder --mac --win",
    "dist:mac": "pnpm build && electron-builder --mac",
    "dist:win": "pnpm build && electron-builder --win"
  },
  "build": {
    "appId": "com.lucy.pencil-pet",
    "productName": "PencilPet",
    "mac": {
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] }
      ],
      "icon": "build/icon.png"
    },
    "directories": {
      "output": "dist"
    },
    "files": ["out/**/*"],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/tray-icon.png",
        "to": "tray-icon.png"
      }
    ]
  },
  "dependencies": {
    "electron-store": "^10.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^3.0.0",
    "typescript": "^5.6.0",
    "vite": "^6.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["electron", "esbuild"]
  }
}
